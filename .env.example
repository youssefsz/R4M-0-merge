# GitHub API Authentication Token
# Get a token from https://github.com/settings/tokens
# Optional but recommended to avoid low unauthenticated rate limits (60 req/hour)
GITHUB_TOKEN=your_github_token_here

# OpenRouter API key used for AI-generated summary and bullets.
# Get one from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Optional: override the default OpenRouter model.
# Example: google/gemini-2.0-flash-lite-preview-02-05:free
OPENROUTER_MODEL=

# Optional: your deployed app URL used for OpenRouter request metadata.
# Example: https://your-app.vercel.app
APP_URL=
